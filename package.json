{
  "name": "@tkfka1/hkclaw",
  "version": "1.2.12",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hkclaw": "dist/hkclaw-cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:runners": "npm --prefix runners/agent-runner install && npm --prefix runners/agent-runner run build && npm --prefix runners/codex-runner install && npm --prefix runners/codex-runner run build",
    "cli": "node dist/hkclaw-cli.js",
    "service:start": "node dist/hkclaw-cli.js start",
    "service:stop": "node dist/hkclaw-cli.js stop",
    "service:restart": "node dist/hkclaw-cli.js restart",
    "service:status": "node dist/hkclaw-cli.js status",
    "restart:hint": "tsx src/restart-context-cli.ts write",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm test && npm run typecheck && npm run build",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "discord.js": "^14.18.0",
    "ffmpeg-static": "^5.3.0",
    "google-tts-api": "^2.0.2",
    "node-edge-tts": "^1.2.10",
    "opusscript": "^0.0.8",
    "phaser": "^3.90.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "prism-media": "^1.3.5",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
