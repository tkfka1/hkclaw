<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.hkclaw-codex</string>
    <key>ProgramArguments</key>
    <array>
        <string>{{NODE_PATH}}</string>
        <string>{{PROJECT_ROOT}}/dist/index.js</string>
    </array>
    <key>WorkingDirectory</key>
    <string>{{PROJECT_ROOT}}</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>{{HOME}}/.npm-global/bin:{{HOME}}/.local/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>{{HOME}}</string>
        <key>ASSISTANT_NAME</key>
        <string>Andy-Codex</string>
        <key>HKCLAW_STORE_DIR</key>
        <string>{{PROJECT_ROOT}}/store-codex</string>
        <key>HKCLAW_GROUPS_DIR</key>
        <string>{{PROJECT_ROOT}}/groups-codex</string>
        <key>HKCLAW_DATA_DIR</key>
        <string>{{PROJECT_ROOT}}/data-codex</string>
    </dict>
    <key>StandardOutPath</key>
    <string>{{PROJECT_ROOT}}/logs/hkclaw-codex.log</string>
    <key>StandardErrorPath</key>
    <string>{{PROJECT_ROOT}}/logs/hkclaw-codex.error.log</string>
</dict>
</plist>
