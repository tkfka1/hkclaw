# ===== HKClaw Agent Overlay =====
# Copy this file to .env.agent.<service_id>.
# Example: .env.agent.ops, .env.agent.codex
# Each employee keeps auth and model settings in its own overlay.

ASSISTANT_NAME=ops
SERVICE_ID=ops
SERVICE_AGENT_TYPE=claude
SERVICE_ROLE=normal
DISCORD_BOT_TOKEN=
STATUS_CHANNEL_ID=

# Claude Code
